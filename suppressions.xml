<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Experimental//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <!-- Excluir clase principal -->
    <suppress files=".*Application\.java" checks=".*"/>
    <!-- Excluir stubs locales de base-ms (disponibles en CI via dependencia) -->
    <suppress files=".*[/\\]basems[/\\].*" checks=".*"/>
    <!-- Excluir stubs locales de common-model (disponibles en CI via dependencia) -->
    <suppress files=".*[/\\]commonmodel[/\\].*" checks=".*"/>
</suppressions>